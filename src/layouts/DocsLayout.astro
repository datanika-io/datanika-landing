---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Datanika documentation" } = Astro.props;

const fullTitle = `${title} — Datanika Docs`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/logo.png", Astro.site);

const articleLD = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonicalURL.href,
  "publisher": {
    "@type": "Organization",
    "name": "Datanika",
    "logo": { "@type": "ImageObject", "url": ogImage.href },
  },
});

// Sidebar IA — 6 collapsible groups (issue #103, see plans/product/SPEC_DOCS_IA_REDESIGN.md).
// Order matters: it's the reading order for someone going from "what is this?" to "running it in prod".
// Add new pages by appending to the relevant group; don't reach for a new top-level entry unless
// you're carving out a new audience (devs, admins, etc.) — that's Approach B territory.
const groups = [
  {
    label: "Getting Started",
    items: [
      { label: "Overview", href: "/docs" },
      { label: "Getting Started", href: "/docs/getting-started" },
      { label: "Architecture", href: "/docs/architecture" },
    ],
  },
  {
    label: "Connect",
    items: [
      // Order matters: connect (Connections) → configure (Connectors) → load
      // (Uploads). The docs-sidebar test enforces the Connections→Connectors
      // →Uploads adjacency as a guardrail for that mental model. File Uploads
      // (the file-import feature) sits at the end of the group as the
      // alternative path for users without a database to connect.
      { label: "Connections", href: "/docs/connections" },
      { label: "Connectors", href: "/docs/connectors" },
      { label: "Uploads", href: "/docs/uploads" },
      { label: "File Uploads", href: "/docs/file-uploads" },
    ],
  },
  {
    label: "Build",
    items: [
      { label: "Transformations", href: "/docs/transformations" },
      { label: "Transformation Guide", href: "/docs/transformations-guide" },
      { label: "Data Catalog", href: "/docs/catalog" },
    ],
  },
  {
    label: "Run & Schedule",
    items: [
      { label: "Pipelines", href: "/docs/pipelines" },
      { label: "Scheduling & Dependencies", href: "/docs/scheduling" },
      { label: "Scheduling Guide", href: "/docs/scheduling-guide" },
      { label: "Runs & Monitoring", href: "/docs/runs" },
    ],
  },
  {
    label: "Operate",
    items: [
      { label: "Organizations & Members", href: "/docs/organizations" },
      { label: "API Keys", href: "/docs/api-keys" },
      { label: "Audit Log", href: "/docs/audit-log" },
      { label: "Self-Hosting", href: "/docs/self-hosting" },
      { label: "Backup & Import", href: "/docs/ai-import" },
    ],
  },
  {
    label: "API & Reference",
    items: [
      { label: "API Reference", href: "/docs/api" },
      { label: "AI Agents", href: "/docs/ai-agents" },
    ],
  },
];

// Flat view kept for code that just needs "every page" — breadcrumb lookup, mobile <select>, tests.
const sections = groups.flatMap((g) => g.items);

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/docs";

// Breadcrumbs: Home → Docs → current page (if not the index)
const currentSection = sections.find(
  (s) => s.href.replace(/\/$/, "") === currentPath
);
const breadcrumbItems = [
  { name: "Home", url: "https://datanika.io/" },
  { name: "Docs", url: "https://datanika.io/docs" },
];
if (currentSection && currentPath !== "/docs") {
  breadcrumbItems.push({
    name: currentSection.label,
    url: new URL(currentPath, Astro.site).href,
  });
}
const breadcrumbLD = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: b.url,
  })),
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Datanika" />
    <meta property="og:image" content={ogImage.href} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />

    <title>{fullTitle}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={articleLD} />
    <script type="application/ld+json" set:html={breadcrumbLD} />
  </head>
  <body class="min-h-screen antialiased">
    <Navbar />
    <div class="mx-auto max-w-7xl px-6 pt-24 pb-16">
      <div class="flex gap-10">
        <!-- Sidebar -->
        <aside class="hidden w-56 shrink-0 md:block">
          <nav class="sticky top-24 max-h-[calc(100vh-7rem)] space-y-3 overflow-y-auto pr-2">
            {groups.map((group) => {
              const groupHasCurrent = group.items.some(
                (i) => i.href.replace(/\/$/, "") === currentPath
              );
              return (
                <details
                  class="group/details"
                  data-sidebar-group={group.label}
                  open={groupHasCurrent}
                >
                  <summary class="flex cursor-pointer list-none items-center gap-1 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-slate-500 select-none hover:text-slate-300">
                    <svg
                      class="h-3 w-3 transition-transform group-open/details:rotate-90"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                    <span>{group.label}</span>
                  </summary>
                  <div class="mt-1 space-y-1">
                    {group.items.map((s) => (
                      <a
                        href={s.href}
                        class:list={[
                          "block rounded-lg px-3 py-2 text-sm transition-colors",
                          currentPath === s.href.replace(/\/$/, "")
                            ? "bg-violet-500/10 text-violet-400 font-medium"
                            : "text-slate-400 hover:text-white hover:bg-slate-800/50",
                        ]}
                      >
                        {s.label}
                      </a>
                    ))}
                  </div>
                </details>
              );
            })}
          </nav>
        </aside>

        <!-- Mobile nav -->
        <div class="mb-6 md:hidden">
          <select
            id="docs-mobile-nav"
            class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-300"
          >
            {groups.map((group) => (
              <optgroup label={group.label}>
                {group.items.map((s) => (
                  <option value={s.href} selected={currentPath === s.href.replace(/\/$/, "")}>
                    {s.label}
                  </option>
                ))}
              </optgroup>
            ))}
          </select>
        </div>

        <!-- Content -->
        <main class="min-w-0 flex-1">
          <div class="prose-docs space-y-6 text-slate-300 leading-relaxed [&_h1]:text-3xl [&_h1]:font-bold [&_h1]:text-white [&_h1]:mb-2 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-white [&_h2]:mt-10 [&_h2]:mb-3 [&_h3]:text-lg [&_h3]:font-medium [&_h3]:text-slate-200 [&_h3]:mt-6 [&_h3]:mb-2 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-1 [&_code]:bg-slate-800 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-violet-300 [&_code]:text-sm [&_pre]:bg-slate-900 [&_pre]:border [&_pre]:border-slate-800 [&_pre]:rounded-lg [&_pre]:p-4 [&_pre]:overflow-x-auto [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_table]:w-full [&_table]:text-sm [&_th]:text-left [&_th]:py-2 [&_th]:px-3 [&_th]:text-slate-400 [&_th]:border-b [&_th]:border-slate-800 [&_td]:py-2 [&_td]:px-3 [&_td]:border-b [&_td]:border-slate-800/50 [&_a]:text-violet-400 [&_a:hover]:underline">
            <slot />
          </div>
        </main>
      </div>
    </div>
    <Footer />

    <script>
      const sel = document.getElementById("docs-mobile-nav") as HTMLSelectElement;
      sel?.addEventListener("change", () => { window.location.href = sel.value; });

      // Persist sidebar group expand/collapse state across pages.
      // Storage key is namespaced under "docs:" so future sidebars (e.g. /api/)
      // can use their own key without colliding.
      const STORAGE_KEY = "docs:sidebar:open-groups";
      type GroupState = Record<string, boolean>;
      function loadState(): GroupState {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}") as GroupState;
        } catch {
          return {};
        }
      }
      function saveState(state: GroupState): void {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
        } catch {
          // localStorage may be disabled (private browsing); fail silently.
        }
      }
      const state = loadState();
      document
        .querySelectorAll<HTMLDetailsElement>("details[data-sidebar-group]")
        .forEach((el) => {
          const name = el.dataset.sidebarGroup;
          if (!name) return;
          // Astro renders the active page's group with `open` already; respect
          // it on first paint so the user lands on a useful sidebar even with
          // empty localStorage. Stored state only overrides for OTHER groups.
          if (!el.open && state[name] === true) el.setAttribute("open", "");
          if (el.open && state[name] === false && !el.querySelector("a.text-violet-400")) {
            el.removeAttribute("open");
          }
          el.addEventListener("toggle", () => {
            const s = loadState();
            s[name] = el.open;
            saveState(s);
          });
        });
    </script>
  </body>
</html>
