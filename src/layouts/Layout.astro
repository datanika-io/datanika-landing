---
import "../styles/global.css";

export interface ArticleMeta {
  publishDate: string | Date;
  modifiedDate?: string | Date;
  author?: string;
  section?: string;
  tags?: string[];
}

export interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  description?: string;
  /**
   * Optional Open Graph image. Pass an absolute URL or a site-relative path
   * (e.g. `/og/my-post.png`).
   *
   * Resolution order:
   *   1. explicit `ogImage` prop
   *   2. auto-derived from `ogCollection` + `ogSlug` (→ `/og/<col>/<slug>.png`)
   *   3. site-wide `/logo.png` fallback
   *
   * Templates should prefer passing `ogCollection` + `ogSlug` rather than
   * hard-coding the path, so a rename of the OG output structure only
   * touches this file.
   */
  ogImage?: string;
  /**
   * Collection name for auto-derived OG image path (e.g. `"blog"`,
   * `"connectors"`, `"use-cases"`, `"compare"`). Paired with `ogSlug`.
   * Ignored if `ogImage` is set explicitly.
   */
  ogCollection?: string;
  /** Slug for auto-derived OG image path. Paired with `ogCollection`. */
  ogSlug?: string;
  /**
   * Open Graph type. Use `"article"` for blog posts and docs to enable
   * Article JSON-LD and the article-specific meta tags. Defaults to
   * `"website"`.
   */
  ogType?: "website" | "article";
  /**
   * Article metadata. Only emitted when `ogType === "article"`. Required
   * fields for valid Article schema: at least a publish date.
   */
  articleMeta?: ArticleMeta;
  /**
   * Breadcrumb trail for the page. When provided, a `BreadcrumbList`
   * JSON-LD block is emitted. Pass site-relative URLs (e.g. `/docs`).
   */
  breadcrumbs?: Breadcrumb[];
  /**
   * Additional Schema.org JSON-LD objects to emit in the `<head>`.
   * Each entry becomes its own `<script type="application/ld+json">`
   * block. Use this for page-specific schemas like `FAQPage`,
   * `SoftwareApplication`, or `Product` that don't fit the built-in
   * Organization / WebSite / Article / BreadcrumbList set.
   */
  extraJsonLd?: object[];
}

const {
  title = "Datanika — Your Data Pipeline Platform",
  description = "Build, orchestrate, and monitor data pipelines with dlt and dbt. Multi-tenant, multi-language, open-source.",
  ogImage,
  ogCollection,
  ogSlug,
  ogType = "website",
  articleMeta,
  breadcrumbs,
  extraJsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Resolution order: explicit ogImage > auto-derived > /logo.png fallback.
// Auto-derivation kicks in when the page passes `ogCollection` + `ogSlug`,
// matching the build-time generation route in `src/pages/og/[...route].ts`.
let resolvedOgImage: string;
if (ogImage) {
  resolvedOgImage = ogImage;
} else if (ogCollection && ogSlug) {
  resolvedOgImage = `/og/${ogCollection}/${ogSlug}.png`;
} else {
  resolvedOgImage = "/logo.png";
}

const ogImageURL = resolvedOgImage.startsWith("http")
  ? resolvedOgImage
  : new URL(resolvedOgImage, Astro.site).href;

const logoURL = new URL("/logo.png", Astro.site).href;

// --- ISO date helpers (Article schema requires ISO 8601) ---

function toISODate(value: string | Date | undefined): string | undefined {
  if (!value) return undefined;
  const d = value instanceof Date ? value : new Date(value);
  if (Number.isNaN(d.getTime())) return undefined;
  return d.toISOString();
}

const publishedISO = articleMeta ? toISODate(articleMeta.publishDate) : undefined;
const modifiedISO = articleMeta
  ? toISODate(articleMeta.modifiedDate ?? articleMeta.publishDate)
  : undefined;

// --- JSON-LD blocks ---

const organizationLD = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Datanika",
  "url": "https://datanika.io",
  "logo": logoURL,
  "sameAs": ["https://github.com/datanika-io/datanika-core"],
});

const webSiteLD = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Datanika",
  "url": "https://datanika.io",
});

const articleLD =
  ogType === "article" && articleMeta
    ? JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "image": ogImageURL,
        "url": canonicalURL.href,
        "datePublished": publishedISO,
        "dateModified": modifiedISO,
        ...(articleMeta.author && {
          "author": { "@type": "Person", "name": articleMeta.author },
        }),
        ...(articleMeta.section && { "articleSection": articleMeta.section }),
        ...(articleMeta.tags && articleMeta.tags.length > 0 && {
          "keywords": articleMeta.tags.join(", "),
        }),
        "publisher": {
          "@type": "Organization",
          "name": "Datanika",
          "logo": { "@type": "ImageObject", "url": logoURL },
        },
      })
    : null;

const breadcrumbLD =
  breadcrumbs && breadcrumbs.length > 0
    ? JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbs.map((b, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": b.name,
          "item": b.url.startsWith("http") ? b.url : new URL(b.url, Astro.site).href,
        })),
      })
    : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Datanika" />
    <meta property="og:image" content={ogImageURL} />

    {ogType === "article" && articleMeta && (
      <>
        {publishedISO && (
          <meta property="article:published_time" content={publishedISO} />
        )}
        {modifiedISO && (
          <meta property="article:modified_time" content={modifiedISO} />
        )}
        {articleMeta.author && (
          <meta property="article:author" content={articleMeta.author} />
        )}
        {articleMeta.section && (
          <meta property="article:section" content={articleMeta.section} />
        )}
        {articleMeta.tags?.map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={organizationLD} />
    <script type="application/ld+json" set:html={webSiteLD} />
    {articleLD && <script type="application/ld+json" set:html={articleLD} />}
    {breadcrumbLD && <script type="application/ld+json" set:html={breadcrumbLD} />}
    {extraJsonLd?.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
    <script defer data-domain="datanika.io" src="https://plausible.datanika.io/js/script.tagged-events.js"></script>
    <!-- Google Ads conversion tracking (AW-18081528527) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18081528527"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-18081528527');
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
