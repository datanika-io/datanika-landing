        Three cases where a different tool will save you money. We'd rather you know up front than sign up and churn.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        {notCheaperCases.map((c) => (
          <div class="rounded-2xl border border-slate-800 bg-slate-900/40 backdrop-blur p-6">
            <h3 class="text-base font-semibold text-white mb-2">{c.title}</h3>
            <p class="text-sm text-slate-400">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Fivetran disclosure (unchanged from V1) -->
  <section class="py-10">
    <div class="max-w-3xl mx-auto px-6">
      <div class="rounded-xl border border-slate-800/80 bg-slate-950/40 p-6 text-xs text-slate-500 leading-relaxed">
        <p class="font-semibold text-slate-400 mb-2">About the Fivetran numbers</p>
        <p>
          Fivetran figures above are illustrative Starter-tier estimates. Actual Fivetran pricing depends on destination, sync frequency, change data capture, historical backfills, and deduplication rules, and changes over time. Run your specific pipeline through <a href="https://www.fivetran.com/pricing" class="text-slate-400 underline hover:text-slate-300" rel="nofollow">Fivetran's own pricing calculator</a> for a binding number. Datanika's per-GB rate is exact — $0.50/GB on Pro, $0.25/GB on Enterprise, with 100 GB and 1 TB included respectively.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Stop paying per row</h2>
      <p class="text-slate-400 mb-8">
        Free tier is $0 forever, 10 GB included. Pro is $79/mo, 100 GB included, $0.50/GB after. Self-host for $0 at any volume.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <ConversionCTA href="https://app.datanika.io" class="btn-primary">Try Datanika Free</ConversionCTA>
        <a href="/compare/fivetran" class="btn-secondary">Full Fivetran comparison</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script define:vars={{ fivetranAnchors, marPerGB, pricing }}>
  function initGbCalculator() {
    const input = document.getElementById("gb-input");
    const slider = document.getElementById("gb-slider");
    const presetButtons = document.querySelectorAll("#gb-presets button");
    const fivetranEl = document.getElementById("result-fivetran");
    const fivetranMarEl = document.getElementById("result-fivetran-mar");
    const datanikaEl = document.getElementById("result-datanika");
    const datanikaTierEl = document.getElementById("result-datanika-tier");
    const datanikaBreakdownEl = document.getElementById("result-datanika-breakdown");
    const savingsEl = document.getElementById("result-savings");

    if (!input || !slider || !fivetranEl) return;

    const MIN_GB = 1;
    const MAX_GB = 10240;
    const LN_MAX = Math.log(MAX_GB);

    // Log-scale mapping: slider (0..100) <-> GB (1..10240). A linear slider
    // wastes 99% of its real estate on sub-100-GB volumes; customers live
    // across 4 orders of magnitude.
    function gbToSlider(gb) {
      const clamped = Math.min(MAX_GB, Math.max(MIN_GB, gb));
      return Math.round((Math.log(clamped) / LN_MAX) * 100);
    }
    function sliderToGb(pos) {
      const frac = Math.max(0, Math.min(100, pos)) / 100;
      return Math.round(Math.exp(frac * LN_MAX));
    }

    // Log-log interpolation across the Fivetran anchor curve. Smooth between
    // tiers rather than snapping.
    function fivetranCostFromMar(mar) {
      if (mar <= 0) return 0;
      if (mar <= fivetranAnchors[0].mar) {
        return Math.round((mar / fivetranAnchors[0].mar) * fivetranAnchors[0].cost);
      }
      if (mar >= fivetranAnchors[fivetranAnchors.length - 1].mar) {
        const a = fivetranAnchors[fivetranAnchors.length - 2];
        const b = fivetranAnchors[fivetranAnchors.length - 1];
        const logSlope =
          (Math.log(b.cost) - Math.log(a.cost)) /
          (Math.log(b.mar) - Math.log(a.mar));
        const logCost =
          Math.log(b.cost) + logSlope * (Math.log(mar) - Math.log(b.mar));
        return Math.round(Math.exp(logCost));
      }
      for (let i = 0; i < fivetranAnchors.length - 1; i++) {
        const a = fivetranAnchors[i];
        const b = fivetranAnchors[i + 1];
        if (mar >= a.mar && mar <= b.mar) {
          const logSlope =
            (Math.log(b.cost) - Math.log(a.cost)) /
            (Math.log(b.mar) - Math.log(a.mar));
          const logCost =
            Math.log(a.cost) + logSlope * (Math.log(mar) - Math.log(a.mar));
          return Math.round(Math.exp(logCost));
        }
      }
      return 0;
    }

    function datanikaBill(gb) {
      const proOver = Math.max(0, gb - pricing.proIncludedGB);
      const entOver = Math.max(0, gb - pricing.entIncludedGB);
      const proTotal = pricing.proBase + proOver * pricing.proOverage;
      const entTotal = pricing.entBase + entOver * pricing.entOverage;

      if (proTotal <= entTotal) {
        return {
          tier: "Datanika Pro",
          total: proTotal,
          breakdown:
            "$" + pricing.proBase + " base + " +
            formatNum(proOver) + " GB × $" + pricing.proOverage.toFixed(2) +
            " = $" + formatNum(Math.round(proTotal)),
        };
      }
      return {
        tier: "Datanika Enterprise",
        total: entTotal,
        breakdown:
          "$" + pricing.entBase + " base + " +
          formatNum(entOver) + " GB × $" + pricing.entOverage.toFixed(2) +
          " = $" + formatNum(Math.round(entTotal)),
      };
    }

    function formatNum(n) {
      return Math.round(n).toLocaleString("en-US");
    }

    function formatMar(mar) {
      if (mar >= 1_000_000) return "~" + (mar / 1_000_000).toFixed(1) + "M";
      if (mar >= 1_000) return "~" + Math.round(mar / 1_000) + "K";
      return "~" + mar;
    }

    // source: "input" | "slider" | "preset"
    function update(source) {
      let gb = Math.max(MIN_GB, parseInt(input.value, 10) || 0);
      if (gb > MAX_GB) gb = MAX_GB;

      // Keep slider and numeric input synced without firing events in a loop.
      if (source !== "slider") slider.value = String(gbToSlider(gb));
      if (source !== "input") input.value = String(gb);

      const mar = gb * marPerGB;
      const fivetranMonthly = fivetranCostFromMar(mar);
      const bill = datanikaBill(gb);
      const savings = Math.max(0, fivetranMonthly - bill.total);

      fivetranEl.textContent = formatNum(fivetranMonthly);
      fivetranMarEl.textContent = formatMar(mar);
      datanikaEl.textContent = formatNum(Math.round(bill.total));
      datanikaTierEl.textContent = bill.tier;
      datanikaBreakdownEl.textContent = bill.breakdown;

      if (fivetranMonthly <= bill.total) {
        savingsEl.textContent = "on par with";
      } else {
        savingsEl.textContent = "$" + formatNum(savings);
      }
    }

    presetButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const gb = btn.getAttribute("data-gb");
        if (gb) {
          input.value = gb;
          update("preset");
        }
      });
    });

    input.addEventListener("input", () => update("input"));
    slider.addEventListener("input", () => {
      input.value = String(sliderToGb(parseInt(slider.value, 10) || 0));
      update("slider");
    });

    update("preset");
  }

  initGbCalculator();
  document.addEventListener("astro:page-load", initGbCalculator);
</script>
