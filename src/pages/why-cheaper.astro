  <!-- When Datanika is NOT cheaper -->
  <section class="py-10">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-white text-center mb-3">When Datanika is <em>not</em> cheaper</h2>
