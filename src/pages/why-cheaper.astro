              <a href="https://www.fivetran.com/pricing" class="underline hover:text-slate-400" rel="nofollow">→ Fivetran's own calculator</a>
            </p>
          </div>

          <!-- Datanika card -->
          <div class="rounded-xl border border-violet-500/50 bg-slate-950/60 p-6 text-center">
            <p class="text-xs uppercase tracking-widest text-violet-400 mb-2">
              <span id="result-datanika-tier">Datanika Pro</span>
            </p>
            <p class="text-5xl font-bold text-white mb-1">
              <span class="text-2xl align-top">$</span><span id="result-datanika">79</span>
            </p>
            <p class="text-sm text-slate-400">per month</p>
