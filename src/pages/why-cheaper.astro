              <span id="result-datanika-breakdown">$79 base + 0 GB × $0.50 = $79</span>
            </p>
            <p class="mt-4 text-xs text-emerald-400">
              You'd save <span id="result-savings">$421</span>/mo vs Fivetran
            </p>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <ConversionCTA href="https://app.datanika.io" class="btn-primary">Start Free (10 GB)</ConversionCTA>
          <a href="/pricing" class="btn-secondary">See full pricing</a>
