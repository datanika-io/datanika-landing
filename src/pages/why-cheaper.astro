---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ConversionCTA from "../components/ConversionCTA.astro";

// DRAFT — Pricing V2 rewrite per SPEC_PRICING_V2.md §7. Lives on branch
// 182-pricing-v2-copy-draft through P1-P4 and merges at P5 cutover day
// alongside cloud's Paddle meter flip. Do NOT merge before cloud volume
// metering has been green in staging for >=14 days.

// Fivetran Starter-tier anchor points (MAR -> monthly cost). Same illustrative
// curve as the landing#160 launch; the disclosure block below tells visitors
// to run Fivetran's own calculator for their specific destination + sync
// frequency. Point of these numbers is the shape of the curve, not a precise
// line-item of Fivetran's bill.
const fivetranAnchors = [
  { mar: 100_000, cost: 120 },
  { mar: 500_000, cost: 250 },
  { mar: 1_000_000, cost: 400 },
  { mar: 5_000_000, cost: 1200 },
  { mar: 10_000_000, cost: 2200 },
  { mar: 25_000_000, cost: 4500 },
];

// Mid-range 5 KB/row means 1 GB ~= 200k rows. This is the pinned conversion
// explained on the page in the "Row sizes used here" section — the honest
// answer to "rows and gigabytes aren't the same thing."
const marPerGB = 200_000;

// Datanika V2 pricing shape. Free caps hard at 10 GB (no overage).
// Pro and Enterprise charge per-GB overage past their included quota.
// Crossover where Enterprise beats Pro+overage: ~740 GB.
const pricing = {
  freeIncludedGB: 10,
  proBase: 79,
  proIncludedGB: 100,
  proOverage: 0.5,
  entBase: 399,
  entIncludedGB: 1024,
  entOverage: 0.25,
};

// 7 preset buttons spanning the pricing-relevant range. 10 GB is visually
// marked as the Free cap; 100 GB is Pro's included quota; 1 TB is
// Enterprise's included quota. These three markers are where paying starts,
// overage kicks in, and the crossover to Enterprise flat sits.
const presets = [
  { gb: 1, label: "1 GB" },
  { gb: 10, label: "10 GB", hint: "Free cap" },
  { gb: 50, label: "50 GB" },
  { gb: 100, label: "100 GB", hint: "Pro quota" },
  { gb: 500, label: "500 GB" },
  { gb: 1024, label: "1 TB", hint: "Enterprise quota" },
  { gb: 10240, label: "10 TB" },
];

// Why MAR pricing hurts — unchanged from V1. The criticism is independent of
// whether our pricing is flat or volume-aware.
const marPains = [
  {
    title: "Growth penalty",
    body: "Your bill scales with success. The product that used to cost $250/mo costs $2,500/mo after you onboard a big customer — without you turning a single dial.",
  },
  {
    title: "Un-budgetable",
    body: "You can't tell finance what next quarter's pipeline bill will be. MAR moves with traffic, deduplication rules, sync frequency, and destination choice.",
  },
  {
    title: "Sync-frequency tax",
    body: "Hourly syncs, change data capture, and historical backfills all inflate MAR. Going from daily → hourly can 5x the same dataset's bill.",
  },
  {
    title: "No room to experiment",
    body: "Every new source you add shows up on the next invoice. Teams self-censor — they stop adding pipelines because the meter is always running.",
  },
];

// datanikaWins rewritten for V2 per SPEC §7.3. Two entries change (flat
// monthly -> subscription + honest overage; runs-not-rows -> bytes-not-rows)
// and two stay (self-host, 32 connectors on every tier).
const datanikaWins = [
  {
    title: "Subscription + honest per-GB overage",
    body: "Pro is $79/mo with 100 GB included and $0.50/GB after. Enterprise is from $399/mo with 1 TB included and $0.25/GB after. The overage rate is visible, the math is in the calculator, and your bill moves with the bytes your pipelines actually touch — not with your schema choices.",
  },
  {
    title: "We charge for bytes processed, not rows inserted",
    body: "A 1M-row narrow table and a 1k-row wide JSON blob can land on the same disk for the same price. MAR tips the bill against wider schemas; GB doesn't care. A row can be 100 bytes or 10 KB, and you pay for the bytes we actually store and move — not for the shape of your source.",
  },
  {
    title: "Self-host if you want",
    body: "The core platform is AGPL-3.0. One docker compose up on your own box and your bill is $0. Every connector and every feature works in self-hosted.",
  },
  {
    title: "All 32 connectors on every tier",
    body: "No per-connection minimums, no locked-behind-Enterprise destinations. The Free tier gets the same connector catalog as Enterprise.",
  },
];

// "When Datanika is NOT cheaper" — honest section converting skeptics per
// SPEC §3.2. Cross-references the spec's "NOT cheaper" language (v3 edit).
const notCheaperCases = [
  {
    title: "True hobby scale (<1 GB/mo, <500K events)",
    body: "Fivetran Free (500K MAR) and Hevo Free (1M events) also cost $0. Our 10 GB Free tier covers the same case with more headroom, but we don't beat free — we tie.",
  },
  {
    title: "Pure-dbt, no extract-and-load work",
    body: "If you already have a warehouse with raw data in it and you just want a dbt orchestrator, dbt Cloud's free tier or a lightweight scheduler will be cheaper than our full platform. We include dbt, but we're priced for teams that need the extract-and-load side too.",
  },
  {
    title: "You need 500+ connectors",
    body: "We have 32 connectors covering the top of the long tail. If your stack depends on a niche SaaS that only Fivetran supports, we're not a drop-in replacement yet — though we ship roughly 2 new connectors per month and take requests seriously.",
  },
];

const pageTitle = "Why Datanika is cheaper than Fivetran — GB Pricing Calculator";
const pageDescription =
  "Fivetran charges per Monthly Active Row. Datanika charges per GB processed, with honest overage. See the side-by-side bill at 1 GB, 100 GB, and 1 TB.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Why cheaper than Fivetran", url: "/why-cheaper" },
  ]}
>
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-violet-600/15 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-[300px] h-[300px] bg-fuchsia-600/10 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <p class="text-sm uppercase tracking-widest text-violet-400 mb-4">Pricing Deep Dive</p>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6">
        You pay for <span class="gradient-text">bytes, not tables</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-4">
        Fivetran charges per Monthly Active Row. Datanika charges per GB processed — $0.50/GB on Pro, $0.25/GB on Enterprise, with 100 GB and 1 TB included.
      </p>
      <p class="text-sm text-slate-500 max-w-xl mx-auto">
        Punch in a monthly volume below and see what MAR pricing costs at the same scale.
      </p>
    </div>
  </section>

  <!-- Honesty disclosure (near hero) -->
  <section class="pb-4">
    <div class="max-w-3xl mx-auto px-6">
      <div class="rounded-xl border border-amber-500/30 bg-amber-500/5 p-5 text-sm text-amber-100/90 leading-relaxed">
        <p class="font-semibold text-amber-300 mb-1">A note on the comparison</p>
        <p>
          This page compares Datanika's per-GB pricing against Fivetran's MAR pricing. Rows and gigabytes aren't the same thing — a row can be 100 bytes or 10 KB. We use a mid-range 5 KB/row conversion to map your GB volume into Fivetran-equivalent MAR; your actual Fivetran bill will sit somewhere in the range the calculator shows. The Datanika side is exact — $0.50/GB is $0.50/GB.
        </p>
      </div>
    </div>
  </section>

  <!-- The Core Idea -->
  <section class="py-12">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur p-8">
          <h3 class="text-sm font-semibold uppercase tracking-widest text-slate-500 mb-3">Fivetran charges for</h3>
          <p class="text-2xl font-bold text-white mb-2">Rows moved (MAR)</p>
          <p class="text-sm text-slate-400">
            Every unique row touched by a sync in a billing month. The wider your schemas and the more frequent your syncs, the higher the MAR count — and every new source compounds it.
          </p>
        </div>
        <div class="rounded-2xl border border-violet-500/40 bg-slate-900/50 backdrop-blur p-8">
          <h3 class="text-sm font-semibold uppercase tracking-widest text-violet-400 mb-3">Datanika charges for</h3>
          <p class="text-2xl font-bold text-white mb-2">Bytes processed (GB)</p>
          <p class="text-sm text-slate-400">
            The actual output bytes our infrastructure touches. A 1M-row narrow table and a 1k-row wide JSON blob land on the same disk for the same price — your schema doesn't get punished.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator -->
  <section id="calculator" class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-white mb-3">GB Pricing Calculator</h2>
        <p class="text-slate-400 max-w-xl mx-auto text-sm">
          Pick a monthly GB volume or type one in. The Datanika card auto-picks whichever tier (<a href="/pricing" class="text-violet-400 hover:text-violet-300 underline">Pro</a> or Enterprise) would be cheaper for your volume.
        </p>
      </div>

      <div class="rounded-2xl border border-slate-800 bg-slate-900/60 backdrop-blur p-6 md:p-10">
        <!-- Preset buttons -->
        <div class="flex flex-wrap justify-center gap-2 mb-8" id="gb-presets">
          {presets.map((preset) => (
