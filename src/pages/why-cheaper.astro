  <!-- Row sizes pinned -->
  <section class="py-10">
    <div class="max-w-3xl mx-auto px-6">
      <div class="rounded-xl border border-slate-800/80 bg-slate-950/40 p-6 text-sm text-slate-400 leading-relaxed">
        <p class="font-semibold text-slate-300 mb-3">Row sizes used here</p>
