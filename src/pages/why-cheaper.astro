      <h2 class="text-3xl font-bold text-white text-center mb-12">How Datanika's model is different</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {datanikaWins.map((win) => (
          <div class="rounded-2xl border border-violet-800/40 bg-slate-900/50 backdrop-blur p-6">
            <h3 class="text-lg font-semibold text-white mb-2">{win.title}</h3>
            <p class="text-sm text-slate-400">{win.body}</p>
          </div>
