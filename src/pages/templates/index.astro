---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ConversionCTA from "../../components/ConversionCTA.astro";
import { templates } from "../../data/templates";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Templates", url: "/templates" },
];
---

<Layout
  title="Pipeline Templates — Datanika"
  description="Pre-configured data pipeline templates: Stripe to PostgreSQL, PostgreSQL to BigQuery, CSV to DuckDB. Schema, merge-mode writes, and dbt-ready staging. Start free."
  breadcrumbs={breadcrumbs}
>
  <Navbar />

  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="glow bg-violet-600 -top-40 -left-40"></div>
    <div class="glow bg-cyan-600 -bottom-40 -right-40"></div>
    <div class="relative max-w-5xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
        <span class="gradient-text">Pipeline Templates</span>
      </h1>
      <p class="text-lg sm:text-xl text-slate-400 max-w-3xl mx-auto leading-relaxed">
        Pre-configured source → destination starters. Sign up, add credentials, and run a real pipeline in minutes — not days.
      </p>
    </div>
  </section>

  <section class="py-10 pb-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {templates.map((tpl) => (
          <a
            href={`/templates/${tpl.slug}`}
            class="rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur p-6 transition-colors hover:border-violet-500/50"
          >
            <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
              <span class="px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">{tpl.source}</span>
              <span class="text-slate-600">→</span>
              <span class="px-2 py-0.5 rounded-full bg-violet-500/20 text-violet-300">{tpl.destination}</span>
            </div>
            <h2 class="text-lg font-bold text-white mb-2">{tpl.h1}</h2>
            <p class="text-sm text-slate-400 line-clamp-2 mb-4">{tpl.tagline}</p>
            <p class="text-xs text-slate-500">{tpl.timeToFirstRun} to first run</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur p-12">
        <h2 class="text-3xl font-bold mb-4">Don't see your stack?</h2>
        <p class="text-slate-400 mb-8 text-lg">
          Datanika supports 32 connectors — any source can pair with any destination, even without a template.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <ConversionCTA href="https://app.datanika.io" class="btn-primary">Start Free</ConversionCTA>
          <a href="/connectors" class="btn-secondary">View all connectors</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
