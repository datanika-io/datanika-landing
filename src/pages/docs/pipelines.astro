---
import DocsLayout from "../../layouts/DocsLayout.astro";
import RelatedConnectors from "../../components/RelatedConnectors.astro";
import { connectors } from "../../data/connectors";

// Connectors used in the Pipeline Templates MVP (core PR #81). Listed here
// as a slug set so the set is the *only* thing curated; names and
// descriptions come from the data file, and a rename or removal in
// connectors.ts will produce an empty or truncated list that the test suite
// catches instead of silently rendering stale metadata.
const TEMPLATE_CONNECTOR_SLUGS = new Set([
  "stripe",        // source: Stripe → Postgres template
  "postgresql",    // source/dest: Stripe → Postgres, Postgres → BigQuery
  "bigquery",      // dest: Postgres → BigQuery
  "csv",           // source: CSV → DuckDB
  "duckdb",        // dest: CSV → DuckDB
]);
const templateConnectors = connectors.filter((c) =>
  TEMPLATE_CONNECTOR_SLUGS.has(c.slug)
);
---

<DocsLayout title="Pipelines">
  <h1>Pipelines</h1>
  <p class="text-lg text-slate-400">Orchestrate multiple transformations as a single dbt pipeline.</p>

  <h2>Overview</h2>
  <p>A <strong>pipeline</strong> executes one or more dbt models together in a single run. While individual transformations can be run standalone, pipelines let you orchestrate them — running selected models with a specific dbt command.</p>

  <h3>Properties</h3>
  <table>
    <thead><tr><th>Field</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td><code>name</code></td><td>Display name (e.g., "Nightly analytics refresh")</td></tr>
      <tr><td><code>description</code></td><td>Optional description</td></tr>
      <tr><td><code>destination_connection</code></td><td>Which database to run against</td></tr>
      <tr><td><code>command</code></td><td>dbt command to execute (see below)</td></tr>
      <tr><td><code>models</code></td><td>List of selected models to run</td></tr>
      <tr><td><code>custom_selector</code></td><td>Optional dbt selector expression for advanced filtering</td></tr>
      <tr><td><code>full_refresh</code></td><td>Force full rebuild of incremental models</td></tr>
      <tr><td><code>status</code></td><td><code>draft</code>, <code>active</code>, <code>paused</code>, or <code>error</code></td></tr>
    </tbody>
  </table>

  <h2>Commands</h2>
  <table>
    <thead><tr><th>Command</th><th>What it does</th></tr></thead>
    <tbody>
      <tr><td><code>run</code></td><td>Build selected models (default)</td></tr>
      <tr><td><code>build</code></td><td>Run models + tests in dependency order</td></tr>
      <tr><td><code>test</code></td><td>Run data quality tests only</td></tr>
      <tr><td><code>seed</code></td><td>Load CSV seed files into the warehouse</td></tr>
      <tr><td><code>snapshot</code></td><td>Execute SCD Type 2 snapshots</td></tr>
      <tr><td><code>compile</code></td><td>Compile SQL without executing (preview)</td></tr>
    </tbody>
  </table>

  <h3>Example</h3>
  <pre><code>Pipeline: "Nightly Analytics Refresh"
Destination: Postgres → Analytics DB
Command: build
Models: [stg_customers, stg_orders, dim_customers, fct_revenue]
Full Refresh: false</code></pre>

  <h2>How to create a pipeline</h2>
  <ol class="list-decimal pl-6 space-y-2">
    <li>Navigate to <strong>Pipelines</strong> in the sidebar</li>
    <li>Click <strong>New Pipeline</strong></li>
    <li>Enter a name and optional description</li>
    <li>Select a <strong>Destination Connection</strong></li>
    <li>Choose a <strong>dbt Command</strong>: <code>build</code> (run + test), <code>run</code>, <code>test</code>, <code>seed</code>, <code>snapshot</code>, or <code>compile</code></li>
    <li>Add models: click <strong>Add Model</strong> and select from your transformations. Optionally include upstream (+) or downstream (+) dependencies</li>
    <li>Alternatively, use a <strong>Custom Selector</strong> for advanced patterns (e.g., <code>tag:nightly</code> or <code>+dim_customers</code>)</li>
    <li>Toggle <strong>Full Refresh</strong> if you want to rebuild incremental models from scratch</li>
    <li>Click <strong>Create Pipeline</strong> to save, then click <strong>Run</strong> to execute</li>
  </ol>

  <h2>Model Selection</h2>
  <p>You can select models to run in two ways:</p>
  <ul>
    <li><strong>Pick from list</strong> — select individual models from the UI</li>
    <li><strong>Custom selector</strong> — use dbt selector syntax for advanced patterns:
      <pre><code>tag:nightly          # all models tagged "nightly"
stg_*                # all staging models
+dim_customers       # dim_customers and all upstream dependencies</code></pre>
    </li>
  </ul>

  <RelatedConnectors
    heading="Connectors in Pipeline Templates"
    description="These connectors power the pre-configured templates in Pipeline Templates — pick a template, plug in credentials, and a working pipeline runs in minutes. See /pipelines/templates inside the app."
    connectors={templateConnectors}
  />
</DocsLayout>
