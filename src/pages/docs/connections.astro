      <tr><td><code>snowflake</code></td><td>Snowflake (account, warehouse, database)</td></tr>
      <tr><td><code>redshift</code></td><td>Amazon Redshift</td></tr>
      <tr><td><code>databricks</code></td><td>Databricks Lakehouse</td></tr>
      <tr><td><code>synapse</code></td><td>Azure Synapse Analytics</td></tr>
    </tbody>
  </table>

  <h3>NoSQL (source only)</h3>
  <table>
    <thead><tr><th>Type</th><th>Notes</th></tr></thead>
    <tbody>
      <tr><td><code>mongodb</code></td><td>MongoDB 4.0+</td></tr>
