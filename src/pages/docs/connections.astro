      <tr><td><code>slack</code></td><td>Channels, messages, users, threads</td></tr>
      <tr><td><code>google_analytics</code></td><td>GA4 reports (property ID + service account)</td></tr>
      <tr><td><code>google_ads</code></td><td>Customers, campaigns, ad groups, ads</td></tr>
      <tr><td><code>facebook_ads</code></td><td>Campaigns, ad sets, ads, leads, creatives</td></tr>
