      <tr><td>Extract + Load</td><td>dlt</td><td>Modern Python-first EL tool</td></tr>
      <tr><td>Transform</td><td>dbt-core</td><td>Industry standard SQL transformations</td></tr>
      <tr><td>Task queue</td><td>Celery + Redis</td><td>Battle-tested async execution</td></tr>
      <tr><td>Scheduling</td><td>APScheduler + PostgreSQL</td><td>Persistent cron jobs across restarts</td></tr>
      <tr><td>Database</td><td>PostgreSQL 16</td><td>ACID, JSONB, IDENTITY columns</td></tr>
      <tr><td>Cache / broker</td><td>Redis 7</td><td>Fast, simple, well-supported</td></tr>
      <tr><td>Auth</td><td>bcrypt + python-jose</td><td>No passlib dependency issues</td></tr>
      <tr><td>Encryption</td><td>cryptography (Fernet)</td><td>Symmetric encryption for credentials</td></tr>
      <tr><td>i18n</td><td>Custom JSON-based</td><td>9 locales, compile-time key validation</td></tr>
    </tbody>
  </table>

