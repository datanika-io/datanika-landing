---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import { isPostVisible } from "../../utils/blog-visibility";

const posts = (await getCollection("blog", ({ data }) => isPostVisible(data)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog — Datanika" description="Insights on data pipelines, ELT, dbt, and building modern data stacks.">
  <Navbar />
  <section class="relative pt-32 pb-20">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
        <span class="gradient-text">Blog</span>
      </h1>
      <p class="text-lg text-slate-400 mb-12">Insights on data pipelines, ELT, dbt, and the modern data stack.</p>

      {posts.length === 0 ? (
        <div class="rounded-2xl border border-slate-800 bg-slate-900/50 p-12 text-center">
          <p class="text-slate-400 text-lg">Coming soon — our first post is on the way.</p>
        </div>
      ) : (
        <div class="space-y-6">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="block rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur p-6 transition-colors hover:border-violet-500/50">
              <div class="flex items-center gap-3 text-sm text-slate-500 mb-2">
                <time datetime={post.data.date.toISOString().slice(0, 10)}>
                  {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                </time>
                <span>·</span>
                <span>{post.data.author}</span>
              </div>
              <h2 class="text-xl font-bold text-white mb-2">{post.data.title}</h2>
              <p class="text-slate-400">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="flex gap-2 mt-3">
                  {post.data.tags.map((tag) => (
                    <span class="text-xs px-2 py-1 rounded-full bg-slate-800 text-slate-400">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
  <Footer />
</Layout>
