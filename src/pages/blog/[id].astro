---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";
import { isPostVisible } from "../../utils/blog-visibility";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => isPostVisible(data));
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const articleMeta = {
  publishDate: post.data.date,
  modifiedDate: post.data.updatedDate ?? post.data.date,
  author: post.data.author,
  section: post.data.category,
  tags: post.data.tags,
};

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog" },
  { name: post.data.title, url: Astro.url.pathname },
];

// OG image resolution: if frontmatter specifies a non-default `heroImage`
// (i.e. Growth uploaded custom art), use it. Otherwise let Layout
// auto-derive from the build-time OG generator at `/og/blog/<slug>.png`.
const hasCustomHero =
  post.data.heroImage && post.data.heroImage !== "/logo.png";
---

<Layout
  title={`${post.data.title} — Datanika Blog`}
  description={post.data.description}
  ogImage={hasCustomHero ? post.data.heroImage : undefined}
  ogCollection="blog"
  ogSlug={post.id}
  ogType="article"
  articleMeta={articleMeta}
  breadcrumbs={breadcrumbs}
>
  <Navbar />
  <article class="relative pt-32 pb-20">
    <div class="max-w-3xl mx-auto px-6">
      <div class="mb-8">
        <div class="flex items-center gap-3 text-sm text-slate-500 mb-4">
          <time datetime={post.data.date.toISOString().slice(0, 10)}>
            {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
          <span>·</span>
          <span>{post.data.author}</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4 gradient-text">{post.data.title}</h1>
        <p class="text-lg text-slate-400">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <div class="flex gap-2 mt-4">
            {post.data.tags.map((tag) => (
              <span class="text-xs px-2 py-1 rounded-full bg-slate-800 text-slate-400">{tag}</span>
            ))}
          </div>
        )}
      </div>
      <div class="prose-docs space-y-6 text-slate-300 leading-relaxed [&_h1]:text-3xl [&_h1]:font-bold [&_h1]:text-white [&_h1]:mb-2 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-white [&_h2]:mt-10 [&_h2]:mb-3 [&_h3]:text-lg [&_h3]:font-medium [&_h3]:text-slate-200 [&_h3]:mt-6 [&_h3]:mb-2 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-1 [&_code]:bg-slate-800 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-violet-300 [&_code]:text-sm [&_pre]:bg-slate-900 [&_pre]:border [&_pre]:border-slate-800 [&_pre]:rounded-lg [&_pre]:p-4 [&_pre]:overflow-x-auto [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_a]:text-violet-400 [&_a:hover]:underline">
        <Content />
      </div>
      <div class="mt-12 pt-8 border-t border-slate-800">
        <a href="/blog" class="text-violet-400 hover:underline">&larr; Back to blog</a>
      </div>
    </div>
  </article>
  <Footer />
</Layout>
