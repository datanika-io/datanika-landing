---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ConversionCTA from "../../components/ConversionCTA.astro";

const features = [
  { name: "Data extraction & loading", datanika: true, airbyte: true },
  { name: "dbt transformations", datanika: true, airbyte: false },
  { name: "Built-in scheduling", datanika: true, airbyte: true },
  { name: "Visual pipeline DAG", datanika: true, airbyte: false },
  { name: "SQL Editor", datanika: true, airbyte: false },
  { name: "File uploads (CSV/JSON/Parquet)", datanika: true, airbyte: false },
  { name: "Data Catalog", datanika: true, airbyte: false },
  { name: "400+ connectors", datanika: false, airbyte: true },
  { name: "Self-host without Kubernetes", datanika: true, airbyte: false },
  { name: "Open-source license (AGPL)", datanika: true, airbyte: false },
  { name: "Multi-language UI (9 languages)", datanika: true, airbyte: false },
  { name: "AI Agent API (/llms.txt + agent guide)", datanika: true, airbyte: false },
];

const chooseDatanika = [
  "You want ELT + transforms + scheduling in one tool",
  "You don't want to manage Kubernetes",
  "You need dbt transformations alongside your EL pipelines",
  "You want a truly open-source platform (AGPL vs ELv2)",
  "You're a small-to-mid team that values simplicity",
];

const chooseAirbyte = [
  "You need 400+ connectors for niche data sources",
  "You already have a separate transformation tool (dbt Cloud, etc.)",
  "You need a mature ecosystem with a large community",
];

// DRAFT — Pricing V2 GB-normalized comparison table per SPEC_PRICING_V2.md §6.1.
// Lives on branch 182-pricing-v2-copy-draft through P1–P4 and merges at P5 cutover.
// Airbyte Cloud numbers are illustrative estimates at ~$10–15/GB range
// (SPEC §3). Airbyte Cloud measures "rows replicated," not GB — hit their
// pricing page for a binding number on your specific sources.
const gbPricingRows = [
  {
    volume: "10 GB / mo",
    note: "Evaluation or side project",
    datanika: "$0",
    datanikaPerGB: "Free tier",
    competitor: "~$200",
    competitorPerGB: "~$20 / GB",
  },
  {
    volume: "100 GB / mo",
    note: "A real production pipeline",
    datanika: "$79",
    datanikaPerGB: "$0.79 / GB",
    competitor: "~$1,500",
    competitorPerGB: "~$15 / GB",
  },
  {
    volume: "1 TB / mo",
    note: "Multi-pipeline data team",
    datanika: "$399",
    datanikaPerGB: "$0.39 / GB",
    competitor: "~$12,000",
    competitorPerGB: "~$12 / GB",
  },
];
---

<Layout
  title="Airbyte Alternative — All-in-One ELT | Datanika"
  description="Airbyte alternative with dbt transforms, scheduling, and a visual pipeline DAG built in. Self-hostable with Docker — no Kubernetes required. Start free."
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Compare", url: "/compare" },
    { name: "Airbyte", url: "/compare/airbyte" },
  ]}
  ogCollection="compare"
  ogSlug="airbyte"
>
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="glow bg-violet-600 -top-40 -left-40"></div>
    <div class="glow bg-cyan-600 -bottom-40 -right-40"></div>
    <div class="relative max-w-5xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
        <span class="gradient-text">Airbyte Alternative</span>
      </h1>
      <p class="text-lg sm:text-xl text-slate-400 max-w-3xl mx-auto leading-relaxed">
        The all-in-one open-source alternative to Airbyte — with built-in
        transforms, scheduling, and a visual pipeline builder.
      </p>
    </div>
  </section>

  <!-- Feature Comparison Table -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Feature Comparison</h2>
      <div class="rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur overflow-hidden">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-slate-800">
              <th class="px-6 py-4 text-sm font-semibold text-slate-300 uppercase tracking-wider">Feature</th>
              <th class="px-6 py-4 text-sm font-semibold text-center text-violet-400 uppercase tracking-wider">Datanika</th>
              <th class="px-6 py-4 text-sm font-semibold text-center text-slate-400 uppercase tracking-wider">Airbyte</th>
            </tr>
          </thead>
          <tbody>
            {features.map((f, i) => (
              <tr class={`border-b border-slate-800/50 ${i % 2 === 0 ? "bg-slate-900/30" : ""}`}>
                <td class="px-6 py-4 text-slate-200">{f.name}</td>
                <td class="px-6 py-4 text-center text-lg">
                  {f.datanika ? (
                    <span class="text-emerald-400">&#10003;</span>
                  ) : (
                    <span class="text-red-400/60">&#10007;</span>
                  )}
                </td>
                <td class="px-6 py-4 text-center text-lg">
                  {f.airbyte ? (
                    <span class="text-emerald-400">&#10003;</span>
                  ) : (
                    <span class="text-red-400/60">&#10007;</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- GB-normalized pricing -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-3">GB-normalized pricing</h2>
      <p class="text-sm text-slate-500 text-center mb-10 max-w-2xl mx-auto">
        How the bill looks at three common volumes. Airbyte Cloud numbers are illustrative estimates — open <a href="/why-cheaper" class="text-violet-400 underline hover:text-violet-300">/why-cheaper</a> for the live GB calculator and the honesty disclosure, or hit <a href="https://airbyte.com/pricing" class="text-slate-400 underline hover:text-slate-300" rel="nofollow">Airbyte&rsquo;s pricing page</a> for a binding number on your specific sources.
      </p>
      <div class="rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur p-8 overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-slate-700">
              <th class="pb-4 pr-4 text-sm font-medium text-slate-400">Monthly volume</th>
              <th class="pb-4 px-4 text-sm font-medium text-violet-400 text-center">Datanika</th>
              <th class="pb-4 pl-4 text-sm font-medium text-slate-400 text-center">Airbyte Cloud</th>
            </tr>
          </thead>
          <tbody>
            {gbPricingRows.map((row) => (
              <tr class="border-b border-slate-800/60">
                <td class="py-4 pr-4 text-sm text-slate-300">
                  <strong class="text-white">{row.volume}</strong>
                  <br /><span class="text-xs text-slate-500">{row.note}</span>
                </td>
                <td class="py-4 px-4 text-center text-sm">
                  <span class="text-white font-mono">{row.datanika}</span>
                  <br /><span class="text-xs text-emerald-400">{row.datanikaPerGB}</span>
                </td>
                <td class="py-4 pl-4 text-center text-sm">
                  <span class="text-slate-300 font-mono">{row.competitor}</span>
                  <br /><span class="text-xs text-slate-500">{row.competitorPerGB}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-slate-600 mt-6 text-center">
        Datanika Free caps at 10 GB/mo. Pro includes 100 GB, $0.50/GB after. Enterprise includes 1 TB, $0.25/GB after. Airbyte self-host is $0 at any volume; Datanika self-host (AGPL-3.0) is $0 at any volume too — the comparison above is the managed paths only.
      </p>
    </div>
  </section>

  <!-- When to Choose -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-8">
      <!-- Choose Datanika -->
      <div class="rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur p-8">
        <h3 class="text-2xl font-bold mb-6">
          When to choose <span class="gradient-text">Datanika</span>
        </h3>
        <ul class="space-y-4">
          {chooseDatanika.map((item) => (
            <li class="flex items-start gap-3">
              <span class="text-emerald-400 mt-0.5 shrink-0">&#10003;</span>
              <span class="text-slate-300">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Choose Airbyte -->
      <div class="rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur p-8">
        <h3 class="text-2xl font-bold mb-6">
          When to choose <span class="text-slate-400">Airbyte</span>
        </h3>
        <ul class="space-y-4">
          {chooseAirbyte.map((item) => (
            <li class="flex items-start gap-3">
              <span class="text-emerald-400 mt-0.5 shrink-0">&#10003;</span>
              <span class="text-slate-300">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- At a Glance -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">At a Glance</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur p-8">
          <h3 class="text-xl font-bold mb-4 gradient-text">Datanika</h3>
          <ul class="space-y-3 text-slate-300 text-sm">
            <li><span class="text-slate-500 font-medium">Scope:</span> All-in-one EL + Transform + Scheduling</li>
            <li><span class="text-slate-500 font-medium">Transforms:</span> dbt built-in (SQL editor, tests, snapshots)</li>
            <li><span class="text-slate-500 font-medium">Connectors:</span> 32 (focused, curated)</li>
            <li><span class="text-slate-500 font-medium">Self-hosting:</span> Single Docker Compose</li>
            <li><span class="text-slate-500 font-medium">License:</span> AGPL-3.0 (truly open source)</li>
            <li><span class="text-slate-500 font-medium">Stack:</span> Python (Reflex), dlt, dbt-core</li>
            <li><span class="text-slate-500 font-medium">Pricing:</span> Free $0 (10 GB/mo) · Pro $79 (100 GB + $0.50/GB) · Ent. from $399 (1 TB + $0.25/GB)</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur p-8">
          <h3 class="text-xl font-bold mb-4 text-slate-400">Airbyte</h3>
          <ul class="space-y-3 text-slate-300 text-sm">
            <li><span class="text-slate-500 font-medium">Scope:</span> EL only (no transforms, no scheduling)</li>
            <li><span class="text-slate-500 font-medium">Transforms:</span> None — need separate dbt Cloud/Core</li>
            <li><span class="text-slate-500 font-medium">Connectors:</span> 400+ (community-maintained, variable quality)</li>
            <li><span class="text-slate-500 font-medium">Self-hosting:</span> Requires Kubernetes for production</li>
            <li><span class="text-slate-500 font-medium">License:</span> ELv2 (not truly open source)</li>
            <li><span class="text-slate-500 font-medium">Stack:</span> Java + Python, Airbyte protocol</li>
            <li><span class="text-slate-500 font-medium">Pricing:</span> Free tier limited, Cloud starts ~$400/mo</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="py-12">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-xl font-bold mb-4">Popular Pipelines</h2>
      <div class="flex flex-wrap gap-3 mb-6">
        <a href="/use-cases/postgresql-to-bigquery" class="text-sm px-3 py-1.5 rounded-full border border-slate-800 text-slate-400 hover:text-white hover:border-violet-500/50 transition-colors">PostgreSQL → BigQuery</a>
        <a href="/use-cases/stripe-to-bigquery" class="text-sm px-3 py-1.5 rounded-full border border-slate-800 text-slate-400 hover:text-white hover:border-violet-500/50 transition-colors">Stripe → BigQuery</a>
        <a href="/use-cases/mongodb-to-snowflake" class="text-sm px-3 py-1.5 rounded-full border border-slate-800 text-slate-400 hover:text-white hover:border-violet-500/50 transition-colors">MongoDB → Snowflake</a>
      </div>
      <h2 class="text-xl font-bold mb-4">Top Connectors</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/connectors/postgresql" class="text-sm px-3 py-1.5 rounded-full border border-slate-800 text-slate-400 hover:text-white hover:border-violet-500/50 transition-colors">PostgreSQL</a>
        <a href="/connectors/bigquery" class="text-sm px-3 py-1.5 rounded-full border border-slate-800 text-slate-400 hover:text-white hover:border-violet-500/50 transition-colors">BigQuery</a>
        <a href="/connectors/snowflake" class="text-sm px-3 py-1.5 rounded-full border border-slate-800 text-slate-400 hover:text-white hover:border-violet-500/50 transition-colors">Snowflake</a>
        <a href="/connectors/stripe" class="text-sm px-3 py-1.5 rounded-full border border-slate-800 text-slate-400 hover:text-white hover:border-violet-500/50 transition-colors">Stripe</a>
        <a href="/connectors/salesforce" class="text-sm px-3 py-1.5 rounded-full border border-slate-800 text-slate-400 hover:text-white hover:border-violet-500/50 transition-colors">Salesforce</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="rounded-2xl border border-slate-800 bg-slate-900/50 backdrop-blur p-12">
        <h2 class="text-3xl font-bold mb-4">Ready to try Datanika?</h2>
        <p class="text-slate-400 mb-8 text-lg">
          Start building data pipelines in minutes — no Kubernetes, no separate
          transform tool, no complexity.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <ConversionCTA href="https://app.datanika.io" class="btn-primary">Start Free</ConversionCTA>
          <a href="https://github.com/datanika-io/datanika-core" class="btn-secondary">View on GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Volume pricing cross-link -->
  <section class="py-8 border-t border-slate-800">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <a href="/features/volume-pricing/" class="text-emerald-400 hover:underline text-sm">
        How our volume-based pricing works — 10 GB free, ETL vs ELT metering, full FAQ →
      </a>
    </div>
  </section>

  <Footer />
</Layout>
