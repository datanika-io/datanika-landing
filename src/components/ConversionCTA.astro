---
// Drop-in replacement for `<a>` that fires Google Ads conversion tracking +
// optional Plausible custom event on click. Uses navigator.sendBeacon() for
// Plausible — survives navigation unlike the XHR+setTimeout path in
// script.tagged-events.js that was losing events on click-then-navigate
// (see landing#212). gtag and Plausible fire from the same inline handler
// for consistent ordering; onclick-attr-based gtag was removed so a single
// script owns the CTA event lifecycle.
//
// Usage:
//   <ConversionCTA href="..." class="btn-primary">Start Free</ConversionCTA>
//   <ConversionCTA href="..." class="btn-primary" plausibleEvent="Pricing: Start free">
//     Start Free
//   </ConversionCTA>
//
// Renders a plain <a> when PUBLIC_GOOGLE_ADS_CONVERSION_LABEL is unset
// (local builds without the secret). The script still handles Plausible
// events in that case as long as plausibleEvent is supplied.
//
// Non-ConversionCTA anchors that want Plausible-only tracking (no gtag) can
// just set `data-plausible-event="Event Name"` — the script matches any
// `a[data-plausible-event]`, not only CTAs rendered by this component.

interface Props {
  href: string;
  class?: string;
  plausibleEvent?: string;
  [key: string]: any;
}

const conversionLabel = import.meta.env.PUBLIC_GOOGLE_ADS_CONVERSION_LABEL;
const sendTo = conversionLabel ? `AW-18081528527/${conversionLabel}` : null;
const { href, class: className, plausibleEvent, ...rest } = Astro.props;
---

<a
  href={href}
  class={className}
  data-plausible-event={plausibleEvent || undefined}
  data-gtag-send-to={sendTo || undefined}
  {...rest}
>
  <slot />
</a>

<script>
  document.addEventListener(
    "click",
    (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;
      const link = target.closest?.(
        "a[data-plausible-event], a[data-gtag-send-to]",
      ) as HTMLAnchorElement | null;
      if (!link) return;

      const href = link.getAttribute("href");
      const eventName = link.getAttribute("data-plausible-event");
      const sendTo = link.getAttribute("data-gtag-send-to");

      const sendPlausible = () => {
        if (!eventName || !navigator.sendBeacon) return;
        try {
          navigator.sendBeacon(
            "https://plausible.datanika.io/api/event",
            JSON.stringify({
              n: eventName,
              u: window.location.href,
              d: "datanika.io",
              r: document.referrer || null,
            }),
          );
        } catch (_) {
          /* sendBeacon rejected (CSP, quota, extension) — silent. */
        }
      };
      const sendGtag = () => {
        const gtag = (window as unknown as { gtag?: (...args: unknown[]) => void }).gtag;
        if (!sendTo || typeof gtag !== "function") return;
        try {
          gtag("event", "conversion", {
            send_to: sendTo,
            value: 1.0,
            currency: "EUR",
          });
        } catch (_) {
          /* gtag threw — silent. */
        }
      };

      const me = e as MouseEvent;
      const isModifierClick =
        me.ctrlKey ||
        me.metaKey ||
        me.shiftKey ||
        (me.button !== undefined && me.button !== 0);

      if (isModifierClick) {
        e.stopImmediatePropagation();
        sendPlausible();
        sendGtag();
        return;
      }

      e.preventDefault();
      e.stopImmediatePropagation();
      sendPlausible();
      sendGtag();
      if (href) setTimeout(() => {
        window.location.href = href;
      }, 50);
    },
    true,
  );
</script>
