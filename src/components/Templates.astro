---
import { templates } from "../data/templates";

const homepageTemplates = templates;
---

<section id="templates" class="relative py-20 md:py-28">
  <div class="glow -top-20 left-1/4 bg-violet-600/40"></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-violet-400">Start from a template</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        First run in minutes, not weeks
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-slate-400">
        Pre-configured source, destination, schema, and a dbt-ready staging layer. Plug in your credentials and run — every knob is filled in for you.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {homepageTemplates.map((tpl) => (
        <a
          href={`/templates/${tpl.slug}`}
          class="group flex flex-col rounded-2xl border border-slate-800 bg-slate-900/50 p-6 backdrop-blur-sm transition-colors hover:border-violet-500/60"
        >
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <span class="rounded-full bg-slate-800 px-2 py-0.5 text-slate-300">{tpl.source}</span>
            <span class="text-slate-600">&rarr;</span>
            <span class="rounded-full bg-violet-500/20 px-2 py-0.5 text-violet-300">{tpl.destination}</span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-white group-hover:text-violet-200">
            {tpl.h1}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400 line-clamp-3">
            {tpl.tagline}
          </p>
          <div class="mt-6 flex items-center justify-between text-xs">
            <span class="text-slate-500">{tpl.timeToFirstRun} to first run</span>
            <span class="font-medium text-violet-400 group-hover:text-violet-300">
              View template &rarr;
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a href="/templates" class="btn-secondary">Browse all templates</a>
    </div>
  </div>
</section>
