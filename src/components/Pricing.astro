---
const tiers = [
  {
    name: "Free",
    monthlyPrice: "$0",
    annualPrice: "$0",
    period: "forever",
    annualPeriod: "forever",
    description: "For individuals exploring data pipelines.",
    features: [
      "1 team member",
      "5 connections",
      "2 schedules",
      "500 model runs / month",
      "All integrations",
      "Social login (Google, GitHub)",
      "Community support",
    ],
    cta: "Get Started",
    highlighted: false,
  },
  {
    name: "Pro",
    monthlyPrice: "$79",
    annualPrice: "$66",
    period: "/month",
    annualPeriod: "/month, billed annually",
    annualTotal: "$790/year",
    description: "For teams that need power and scale.",
    features: [
      "5 team members",
      "25 connections",
      "Unlimited schedules",
      "15,000 model runs / month",
      "All integrations",
      "Social login (Google, GitHub)",
      "Priority support",
    ],
    cta: "Start Free Trial",
    highlighted: true,
  },
  {
    name: "Enterprise",
    monthlyPrice: "From $399",
    annualPrice: "From $333",
    period: "/month",
    annualPeriod: "/month, billed annually",
    annualTotal: "From $3,990/year",
    description: "For organizations with advanced needs. Extra seats at $25/mo each.",
    features: [
      "10 team members included",
      "50 connections",
      "Unlimited schedules",
      "50,000 model runs / month",
      "Overage: $0.01 / run",
      "SSO (SAML/OIDC)",
      "Priority support with SLA",
    ],
    cta: "Contact Us",
    ctaHref: "mailto:info@datanika.io",
    highlighted: false,
  },
];
---

<section id="pricing" class="relative py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Simple, transparent <span class="gradient-text">pricing</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Start free and scale as your data needs grow. No per-row fees, no surprise bills.
      </p>

      <!-- Monthly / Annual Toggle -->
      <div class="mt-8 inline-flex items-center gap-3 rounded-full border border-slate-800 bg-slate-900/80 p-1">
        <button
          id="toggle-monthly"
          class="rounded-full px-5 py-2 text-sm font-medium transition-colors bg-violet-500/20 text-violet-300"
          data-billing="monthly"
        >
          Monthly
        </button>
        <button
          id="toggle-annual"
          class="rounded-full px-5 py-2 text-sm font-medium transition-colors text-slate-400 hover:text-white"
          data-billing="annual"
        >
          Annual <span class="ml-1 text-xs text-emerald-400">Save 17%</span>
        </button>
      </div>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3 max-w-5xl mx-auto">
      {tiers.map((tier) => (
        <div
          class:list={[
            "relative rounded-xl border p-8 transition-colors",
            tier.highlighted
              ? "border-violet-500/50 bg-slate-900"
              : "border-slate-800 bg-slate-900/50 hover:border-slate-700",
          ]}
        >
          {tier.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-violet-500 to-cyan-400 px-4 py-1 text-xs font-bold text-white">
              Most Popular
            </div>
          )}

          <h3 class="text-xl font-semibold text-white">{tier.name}</h3>
          <p class="mt-2 text-sm text-slate-400">{tier.description}</p>

          <div class="mt-6">
            <div class="flex items-baseline gap-1" data-price="monthly">
              <span class="text-4xl font-bold text-white">{tier.monthlyPrice}</span>
              {tier.period && <span class="text-slate-400">{tier.period}</span>}
            </div>
            <div class="hidden items-baseline gap-1" data-price="annual">
              <span class="text-4xl font-bold text-white">{tier.annualPrice}</span>
              {tier.annualPeriod && <span class="text-slate-400">{tier.annualPeriod}</span>}
            </div>
          </div>

          <ul class="mt-8 space-y-3">
            {tier.features.map((feature) => (
              <li class="flex items-center gap-3 text-sm text-slate-300">
                <svg class="h-4 w-4 shrink-0 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <a
            href={tier.ctaHref || "https://app.datanika.io"}
            class:list={[
              "mt-8 block w-full rounded-lg py-3 text-center text-sm font-semibold transition-colors",
              tier.highlighted
                ? "btn-primary"
                : "btn-secondary",
              tier.ctaHref
                ? "plausible-event-name=Pricing:+Contact+sales"
                : "plausible-event-name=Pricing:+Start+free",
            ]}
          >
            {tier.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initPricingToggle() {
    const monthlyBtn = document.getElementById("toggle-monthly");
    const annualBtn = document.getElementById("toggle-annual");
    const monthlyPrices = document.querySelectorAll('[data-price="monthly"]');
    const annualPrices = document.querySelectorAll('[data-price="annual"]');

    if (!monthlyBtn || !annualBtn) return;

    function showMonthly() {
      monthlyBtn!.classList.add("bg-violet-500/20", "text-violet-300");
      monthlyBtn!.classList.remove("text-slate-400", "hover:text-white");
      annualBtn!.classList.remove("bg-violet-500/20", "text-violet-300");
      annualBtn!.classList.add("text-slate-400", "hover:text-white");
      monthlyPrices.forEach((el) => { el.classList.remove("hidden"); el.classList.add("flex"); });
      annualPrices.forEach((el) => { el.classList.add("hidden"); el.classList.remove("flex"); });
    }

    function showAnnual() {
      annualBtn!.classList.add("bg-violet-500/20", "text-violet-300");
      annualBtn!.classList.remove("text-slate-400", "hover:text-white");
      monthlyBtn!.classList.remove("bg-violet-500/20", "text-violet-300");
      monthlyBtn!.classList.add("text-slate-400", "hover:text-white");
      annualPrices.forEach((el) => { el.classList.remove("hidden"); el.classList.add("flex"); });
      monthlyPrices.forEach((el) => { el.classList.add("hidden"); el.classList.remove("flex"); });
    }

    monthlyBtn.addEventListener("click", showMonthly);
    annualBtn.addEventListener("click", showAnnual);
  }

  initPricingToggle();
  document.addEventListener("astro:page-load", initPricingToggle);
</script>
