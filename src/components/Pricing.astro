---
const tiers = [
  {
    name: "Free",
    monthlyPrice: "$0",
    annualPrice: "$0",
    monthlyPeriod: "forever",
    annualPeriod: "forever",
    description: "For individuals exploring data pipelines.",
    features: [
      "1 team member",
      "5 connections",
      "2 schedules",
      "500 model runs / month",
      "All integrations",
      "Social login (Google, GitHub)",
      "Community support",
    ],
    cta: "Get Started",
    highlighted: false,
  },
  {
    name: "Pro",
    monthlyPrice: "$79",
    annualPrice: "$790",
    monthlyPeriod: "/month",
    annualPeriod: "/year",
    description: "For teams that need power and scale.",
    features: [
      "5 team members",
      "25 connections",
      "Unlimited schedules",
      "15,000 model runs / month",
      "All integrations",
      "Social login (Google, GitHub)",
      "Priority support",
    ],
    cta: "Start Free Trial",
    highlighted: true,
  },
  {
    name: "Enterprise",
    monthlyPrice: "From $399",
    annualPrice: "From $3,990",
    monthlyPeriod: "/month",
    annualPeriod: "/year",
    description: "For organizations with advanced needs. Extra seats at $25/mo each.",
    features: [
      "10 team members included",
      "50 connections",
      "Unlimited schedules",
      "50,000 model runs / month",
      "Overage: $0.01 / run",
      "SSO (SAML/OIDC)",
      "Priority support with SLA",
    ],
    cta: "Contact Us",
    ctaHref: "mailto:info@datanika.io",
    highlighted: false,
  },
];
---

<section id="pricing" class="relative py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Simple, transparent <span class="gradient-text">pricing</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Start free and scale as your data needs grow. No per-row fees, no surprise bills.
      </p>

      <!-- Monthly / Annual Toggle -->
      <div class="mt-8 inline-flex items-center gap-3 rounded-full border border-slate-700 bg-slate-900/80 p-1.5">
        <button
          id="btn-monthly"
          class="rounded-full px-5 py-2 text-sm font-semibold transition-all bg-violet-600 text-white"
          onclick="setInterval('monthly')"
        >
          Monthly
        </button>
        <button
          id="btn-annual"
          class="rounded-full px-5 py-2 text-sm font-semibold transition-all text-slate-400 hover:text-white"
          onclick="setInterval('annual')"
        >
          Annual
          <span class="ml-1.5 inline-block rounded-full bg-green-500/20 px-2 py-0.5 text-xs font-bold text-green-400">
            Save 17%
          </span>
        </button>
      </div>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3 max-w-5xl mx-auto">
      {tiers.map((tier, i) => (
        <div
          class:list={[
            "relative rounded-xl border p-8 transition-colors",
            tier.highlighted
              ? "border-violet-500/50 bg-slate-900"
              : "border-slate-800 bg-slate-900/50 hover:border-slate-700",
          ]}
        >
          {tier.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-violet-500 to-cyan-400 px-4 py-1 text-xs font-bold text-white">
              Most Popular
            </div>
          )}

          <h3 class="text-xl font-semibold text-white">{tier.name}</h3>
          <p class="mt-2 text-sm text-slate-400">{tier.description}</p>

          <div class="mt-6 flex items-baseline gap-1">
            <span
              class="text-4xl font-bold text-white"
              data-monthly-price={tier.monthlyPrice}
              data-annual-price={tier.annualPrice}
              id={`price-${i}`}
            >
              {tier.monthlyPrice}
            </span>
            <span
              class="text-slate-400"
              data-monthly-period={tier.monthlyPeriod}
              data-annual-period={tier.annualPeriod}
              id={`period-${i}`}
            >
              {tier.monthlyPeriod}
            </span>
          </div>

          <ul class="mt-8 space-y-3">
            {tier.features.map((feature) => (
              <li class="flex items-center gap-3 text-sm text-slate-300">
                <svg class="h-4 w-4 shrink-0 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <a
            href={tier.ctaHref || "https://app.datanika.io"}
            class:list={[
              "mt-8 block w-full rounded-lg py-3 text-center text-sm font-semibold transition-colors",
              tier.highlighted
                ? "btn-primary"
                : "btn-secondary",
            ]}
          >
            {tier.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  function setInterval(interval) {
    const btnMonthly = document.getElementById('btn-monthly');
    const btnAnnual = document.getElementById('btn-annual');

    if (interval === 'monthly') {
      btnMonthly.className = 'rounded-full px-5 py-2 text-sm font-semibold transition-all bg-violet-600 text-white';
      btnAnnual.className = 'rounded-full px-5 py-2 text-sm font-semibold transition-all text-slate-400 hover:text-white';
    } else {
      btnAnnual.className = 'rounded-full px-5 py-2 text-sm font-semibold transition-all bg-violet-600 text-white';
      btnMonthly.className = 'rounded-full px-5 py-2 text-sm font-semibold transition-all text-slate-400 hover:text-white';
    }

    for (let i = 0; i < 3; i++) {
      const priceEl = document.getElementById(`price-${i}`);
      const periodEl = document.getElementById(`period-${i}`);
      if (priceEl && periodEl) {
        priceEl.textContent = interval === 'monthly'
          ? priceEl.dataset.monthlyPrice
          : priceEl.dataset.annualPrice;
        periodEl.textContent = interval === 'monthly'
          ? periodEl.dataset.monthlyPeriod
          : periodEl.dataset.annualPeriod;
      }
    }
  }
</script>
