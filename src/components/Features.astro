---

<section id="features" class="relative py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Everything you need to manage your
        <span class="gradient-text">data pipelines</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        From extraction to analytics, Datanika handles the entire data lifecycle.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => {
        const Tag = feature.href ? "a" : "div";
        return (
          <Tag href={feature.href} class="group rounded-xl border border-slate-800 bg-slate-900/50 p-6 transition-colors hover:border-slate-700">
            <div class="mb-4 inline-flex rounded-lg bg-violet-500/10 p-3 text-violet-400">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="mb-2 text-lg font-semibold text-white">{feature.title}</h3>
            <p class="text-sm leading-relaxed text-slate-400">{feature.description}</p>
          </Tag>
        );
      })}
    </div>
  </div>
</section>
