---
/**
 * Accessible FAQ accordion using native `<details>`/`<summary>`.
 * No JavaScript required; works with keyboard and screen readers out of
 * the box. Pair with `buildFaqPageJsonLd()` from the same data source
 * to emit matching `FAQPage` JSON-LD without drift.
 */
import type { FAQItem } from "../data/pricing-faq";

interface Props {
  items: FAQItem[];
  title?: string;
  description?: string;
}

const {
  items,
  title = "Frequently asked questions",
  description,
} = Astro.props;
---

<section class="relative py-20">
  <div class="mx-auto max-w-3xl px-6">
    <div class="mb-10 text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">{title}</h2>
      {description && (
        <p class="mt-4 text-lg text-slate-400">{description}</p>
      )}
    </div>

    <div class="space-y-3">
      {items.map((item) => (
        <details
          class="group rounded-xl border border-slate-800 bg-slate-900/50 backdrop-blur transition-colors hover:border-slate-700"
        >
          <summary
            class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5 text-left font-medium text-white marker:hidden [&::-webkit-details-marker]:hidden"
          >
            <span class="text-base sm:text-lg">{item.question}</span>
            <svg
              class="h-5 w-5 shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-180"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </summary>
          <div class="px-6 pb-5 text-slate-300 leading-relaxed">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
