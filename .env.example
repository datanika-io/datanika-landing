# datanika-landing — environment variables
#
# Copy to .env (gitignored) for local development. CI reads these from
# GitHub Actions secrets.

# Google Ads conversion tracking label.
#
# This is the label suffix used by /signup conversion events on Start
# Free / Get Started CTAs. Combined with the AW account ID
# (AW-18081528527, public, in Layout.astro) to form the full send_to.
#
# Where to find the real value:
#   D:/Projects/Datanika/secrets/google-ads-api.env
#   (line: event_snippet → 'send_to': 'AW-18081528527/<LABEL>')
#
# When unset (e.g. local builds without the secret), ConversionCTA.astro
# renders a plain <a> with no onclick — site still works, conversions
# just aren't tracked. Production CI must set this for attribution to
# work in Google Ads.
PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=replace_with_real_label
